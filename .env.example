# ── REQUIRED ────────────────────────────────────────────────────────────────
# Database (auto-set by DigitalOcean managed database, or build manually)
DATABASE_URL=postgresql://user:password@localhost:5432/water_sentinel

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-64-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API key for sensor ingest endpoint
API_KEY_SECRET=change-me-api-key-secret-min-64-chars

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BASE_URL=http://localhost:3001

# OpenRouter AI (optional for AI analysis features)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# PDF reports
PDF_OUTPUT_DIR=./reports

# ── SATELLITE DATA — FEATURE FLAGS ──────────────────────────────────────────

# USGS National Water Information System (no API key needed — completely open)
USGS_NWIS_ENABLED=true

# Copernicus Marine Service (CMEMS)
# Register free at: https://marine.copernicus.eu
CMEMS_USERNAME=your-cmems-username
CMEMS_PASSWORD=your-cmems-password
CMEMS_ENABLED=false

# NASA Earthdata (MODIS/VIIRS ocean colour)
# Register free at: https://urs.earthdata.nasa.gov
EARTHDATA_USERNAME=your-earthdata-username
EARTHDATA_PASSWORD=your-earthdata-password
EARTHDATA_ENABLED=false
# Legacy token-based auth (optional)
NASA_EARTHDATA_TOKEN=your-nasa-earthdata-token

# OpenWeatherMap weather context
# Register free at: https://openweathermap.org/api (1000 calls/day free tier)
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
OPENWEATHERMAP_ENABLED=false

# European Environment Agency Waterbase (no key needed)
EEA_ENABLED=false

# Legacy Copernicus Dataspace (OAuth2 client credentials)
COPERNICUS_CLIENT_ID=your-copernicus-client-id
COPERNICUS_CLIENT_SECRET=your-copernicus-client-secret

# Legacy USGS Water Quality Portal base URL
USGS_WQP_BASE_URL=https://www.waterqualitydata.us

# ── EMAIL NOTIFICATIONS (optional) ──────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@yourdomain.com

# ── MQTT IoT SENSORS (optional) ─────────────────────────────────────────────
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://your-broker:1883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password

# ── REDIS CACHE (optional — falls back to in-memory if disabled) ─────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
