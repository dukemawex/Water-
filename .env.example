# Database
DATABASE_URL=postgresql://user:password@localhost:5432/water_sentinel

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenRouter AI
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# NASA Earthdata (open, free registration)
NASA_EARTHDATA_TOKEN=your-nasa-token

# Copernicus/Sentinel Hub (open, free tier)
COPERNICUS_CLIENT_ID=your-copernicus-client-id
COPERNICUS_CLIENT_SECRET=your-copernicus-client-secret

# USGS Water Quality Portal (no auth needed - completely open)
USGS_WQP_BASE_URL=https://www.waterqualitydata.us

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_KEY_SECRET=change-me-api-key

# PDF
PDF_OUTPUT_DIR=./reports
